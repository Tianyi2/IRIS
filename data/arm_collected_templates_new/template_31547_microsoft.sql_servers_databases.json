{
  "properties": {
    "displayName": "Deploy Diagnostic Settings for Microsoft.Sql/servers/databases to Azure Native Dynatrace Service",
    "policyType": "Custom",
    "mode": "Indexed",
    "version": "1.0.0",
    "description": "This policy enables diagnostic settings for Microsoft.Sql/servers/databases to send all available logs to a Dynatrace environment.",
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Enable or disable the execution of the policy"
        },
        "allowedValues": [
          "DeployIfNotExists",
          "AuditIfNotExists",
          "Disabled"
        ],
        "defaultValue": "DeployIfNotExists"
      },
      "diagnosticSettingName": {
        "type": "String",
        "metadata": {
          "displayName": "Diagnostic Setting Name",
          "description": "The name of the diagnostic setting to create."
        },
        "defaultValue": "setByPolicy-Dynatrace"
      },
      "resourceLocationList": {
        "type": "Array",
        "metadata": {
          "displayName": "Resource Location List",
          "description": "List of resource locations to which this policy is applied."
        },
        "defaultValue": [
          "*"
        ]
      },
      "dynatraceResource": {
        "type": "String",
        "metadata": {
          "displayName": "Azure Native Dynatrace Service",
          "description": "Azure Native Dynatrace Service resource id",
          "strongType": "Dynatrace.Observability/monitors",
          "assignPermissions": true
        }
      }
    },
    "automatictuningEnabled": {
      "type": "bool",
      "metadata": {
        "displayName": "AutomaticTuning",
        "description": "Enable or disable log category AutomaticTuning"
      },
      "defaultValue": true
    },
    "blocksEnabled": {
      "type": "bool",
      "metadata": {
        "displayName": "Blocks",
        "description": "Enable or disable log category Blocks"
      },
      "defaultValue": true
    },
    "databasewaitstatisticsEnabled": {
      "type": "bool",
      "metadata": {
        "displayName": "DatabaseWaitStatistics",
        "description": "Enable or disable log category DatabaseWaitStatistics"
      },
      "defaultValue": true
    },
    "deadlocksEnabled": {
      "type": "bool",
      "metadata": {
        "displayName": "Deadlocks",
        "description": "Enable or disable log category Deadlocks"
      },
      "defaultValue": true
    },
    "devopsoperationsauditEnabled": {
      "type": "bool",
      "metadata": {
        "displayName": "DevOpsOperationsAudit",
        "description": "Enable or disable log category DevOpsOperationsAudit"
      },
      "defaultValue": true
    },
    "dmsworkersEnabled": {
      "type": "bool",
      "metadata": {
        "displayName": "DmsWorkers",
        "description": "Enable or disable log category DmsWorkers"
      },
      "defaultValue": true
    },
    "errorsEnabled": {
      "type": "bool",
      "metadata": {
        "displayName": "Errors",
        "description": "Enable or disable log category Errors"
      },
      "defaultValue": true
    },
    "execrequestsEnabled": {
      "type": "bool",
      "metadata": {
        "displayName": "ExecRequests",
        "description": "Enable or disable log category ExecRequests"
      },
      "defaultValue": true
    },
    "querystoreruntimestatisticsEnabled": {
      "type": "bool",
      "metadata": {
        "displayName": "QueryStoreRuntimeStatistics",
        "description": "Enable or disable log category QueryStoreRuntimeStatistics"
      },
      "defaultValue": true
    },
    "querystorewaitstatisticsEnabled": {
      "type": "bool",
      "metadata": {
        "displayName": "QueryStoreWaitStatistics",
        "description": "Enable or disable log category QueryStoreWaitStatistics"
      },
      "defaultValue": true
    },
    "requeststepsEnabled": {
      "type": "bool",
      "metadata": {
        "displayName": "RequestSteps",
        "description": "Enable or disable log category RequestSteps"
      },
      "defaultValue": true
    },
    "sqlinsightsEnabled": {
      "type": "bool",
      "metadata": {
        "displayName": "SQLInsights",
        "description": "Enable or disable log category SQLInsights"
      },
      "defaultValue": true
    },
    "sqlrequestsEnabled": {
      "type": "bool",
      "metadata": {
        "displayName": "SqlRequests",
        "description": "Enable or disable log category SqlRequests"
      },
      "defaultValue": true
    },
    "sqlsecurityauditeventsEnabled": {
      "type": "bool",
      "metadata": {
        "displayName": "SQLSecurityAuditEvents",
        "description": "Enable or disable log category SQLSecurityAuditEvents"
      },
      "defaultValue": true
    },
    "timeoutsEnabled": {
      "type": "bool",
      "metadata": {
        "displayName": "Timeouts",
        "description": "Enable or disable log category Timeouts"
      },
      "defaultValue": true
    },
    "waitsEnabled": {
      "type": "bool",
      "metadata": {
        "displayName": "Waits",
        "description": "Enable or disable log category Waits"
      },
      "defaultValue": true
    }
  },
  "policyRule": {
    "if": {
      "allOf": [
        {
          "field": "type",
          "equals": "Microsoft.Sql/servers/databases"
        },
        {
          "anyOf": [
            {
              "value": "[first(parameters('resourceLocationList'))]",
              "equals": "*"
            },
            {
              "field": "location",
              "in": "[parameters('resourceLocationList')]"
            }
          ]
        }
      ]
    },
    "then": {
      "effect": "[parameters('effect')]",
      "details": {
        "type": "Microsoft.Insights/diagnosticSettings",
        "existenceCondition": {
          "allOf": [
            {
              "count": {
                "field": "Microsoft.Insights/diagnosticSettings/logs[*]",
                "where": {
                  "anyOf": [
                    {
                      "field": "Microsoft.Insights/diagnosticSettings/logs[*].enabled",
                      "equals": true
                    }
                  ]
                }
              },
              "greaterOrEquals": 1
            },
            {
              "field": "Microsoft.Insights/diagnosticSettings/marketplacePartnerId",
              "equals": "[parameters('dynatraceResource')]"
            }
          ]
        },
        "deployment": {
          "properties": {
            "mode": "incremental",
            "template": {
              "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
              "contentVersion": "1.0.0.0",
              "parameters": {
                "resourceName": {
                  "type": "string"
                },
                "diagnosticSettingName": {
                  "type": "string"
                },
                "dynatraceResource": {
                  "type": "string"
                },
                "logs": {
                  "type": "array"
                }
              },
              "variables": {},
              "resources": [
                {
                  "type": "Microsoft.Sql/servers/databases/providers/diagnosticSettings",
                  "apiVersion": "2021-05-01-preview",
                  "name": "[concat(parameters('resourceName'), '/', parameters('diagnosticSettingName'))]",
                  "properties": {
                    "workspaceId": "[parameters('dynatraceResource')]",
                    "logs": "[parameters('logs')]"
                  }
                }
              ],
              "outputs": {
                "policy": {
                  "type": "string",
                  "value": "[concat('Diagnostic setting ', parameters('diagnosticSettingName'), ' for type Microsoft.Sql/servers/databases, resourceName ', parameters('resourceName'), ' to Azure Native Dynatrace Service ', parameters('dynatraceResource'), ' configured')]"
                }
              }
            },
            "parameters": {
              "resourceName": {
                "value": "[field('name')]"
              },
              "diagnosticSettingName": {
                "value": "[parameters('diagnosticSettingName')]"
              },
              "dynatraceResource": {
                "value": "[parameters('dynatraceResource')]"
              },
              "logs": {
                "value": [
                  {
                    "category": "AutomaticTuning",
                    "enabled": "[parameters('automatictuningEnabled')]"
                  },
                  {
                    "category": "Blocks",
                    "enabled": "[parameters('blocksEnabled')]"
                  },
                  {
                    "category": "DatabaseWaitStatistics",
                    "enabled": "[parameters('databasewaitstatisticsEnabled')]"
                  },
                  {
                    "category": "Deadlocks",
                    "enabled": "[parameters('deadlocksEnabled')]"
                  },
                  {
                    "category": "DevOpsOperationsAudit",
                    "enabled": "[parameters('devopsoperationsauditEnabled')]"
                  },
                  {
                    "category": "DmsWorkers",
                    "enabled": "[parameters('dmsworkersEnabled')]"
                  },
                  {
                    "category": "Errors",
                    "enabled": "[parameters('errorsEnabled')]"
                  },
                  {
                    "category": "ExecRequests",
                    "enabled": "[parameters('execrequestsEnabled')]"
                  },
                  {
                    "category": "QueryStoreRuntimeStatistics",
                    "enabled": "[parameters('querystoreruntimestatisticsEnabled')]"
                  },
                  {
                    "category": "QueryStoreWaitStatistics",
                    "enabled": "[parameters('querystorewaitstatisticsEnabled')]"
                  },
                  {
                    "category": "RequestSteps",
                    "enabled": "[parameters('requeststepsEnabled')]"
                  },
                  {
                    "category": "SQLInsights",
                    "enabled": "[parameters('sqlinsightsEnabled')]"
                  },
                  {
                    "category": "SqlRequests",
                    "enabled": "[parameters('sqlrequestsEnabled')]"
                  },
                  {
                    "category": "SQLSecurityAuditEvents",
                    "enabled": "[parameters('sqlsecurityauditeventsEnabled')]"
                  },
                  {
                    "category": "Timeouts",
                    "enabled": "[parameters('timeoutsEnabled')]"
                  },
                  {
                    "category": "Waits",
                    "enabled": "[parameters('waitsEnabled')]"
                  }
                ]
              }
            }
          }
        }
      }
    }
  }
}
