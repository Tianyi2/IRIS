{
  "properties": {
    "displayName": "Deploy Diagnostic Settings for Microsoft.ManagedNetworkFabric/networkDevices to Azure Native Dynatrace Service",
    "policyType": "Custom",
    "mode": "Indexed",
    "version": "1.0.0",
    "description": "This policy enables diagnostic settings for Microsoft.ManagedNetworkFabric/networkDevices to send all available logs to a Dynatrace environment.",
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Enable or disable the execution of the policy"
        },
        "allowedValues": [
          "DeployIfNotExists",
          "AuditIfNotExists",
          "Disabled"
        ],
        "defaultValue": "DeployIfNotExists"
      },
      "diagnosticSettingName": {
        "type": "String",
        "metadata": {
          "displayName": "Diagnostic Setting Name",
          "description": "The name of the diagnostic setting to create."
        },
        "defaultValue": "setByPolicy-Dynatrace"
      },
      "resourceLocationList": {
        "type": "Array",
        "metadata": {
          "displayName": "Resource Location List",
          "description": "List of resource locations to which this policy is applied."
        },
        "defaultValue": [
          "*"
        ]
      },
      "dynatraceResource": {
        "type": "String",
        "metadata": {
          "displayName": "Azure Native Dynatrace Service",
          "description": "Azure Native Dynatrace Service resource id",
          "strongType": "Dynatrace.Observability/monitors",
          "assignPermissions": true
        }
      }
    },
    "bfdstateupdatesEnabled": {
      "type": "bool",
      "metadata": {
        "displayName": "BfdStateUpdates",
        "description": "Enable or disable log category BfdStateUpdates"
      },
      "defaultValue": true
    },
    "componentstateupdatesEnabled": {
      "type": "bool",
      "metadata": {
        "displayName": "ComponentStateUpdates",
        "description": "Enable or disable log category ComponentStateUpdates"
      },
      "defaultValue": true
    },
    "interfacestateupdatesEnabled": {
      "type": "bool",
      "metadata": {
        "displayName": "InterfaceStateUpdates",
        "description": "Enable or disable log category InterfaceStateUpdates"
      },
      "defaultValue": true
    },
    "interfacevxlanupdatesEnabled": {
      "type": "bool",
      "metadata": {
        "displayName": "InterfaceVxlanUpdates",
        "description": "Enable or disable log category InterfaceVxlanUpdates"
      },
      "defaultValue": true
    },
    "networkinstancebgpneighborupdatesEnabled": {
      "type": "bool",
      "metadata": {
        "displayName": "NetworkInstanceBgpNeighborUpdates",
        "description": "Enable or disable log category NetworkInstanceBgpNeighborUpdates"
      },
      "defaultValue": true
    },
    "networkinstanceupdatesEnabled": {
      "type": "bool",
      "metadata": {
        "displayName": "NetworkInstanceUpdates",
        "description": "Enable or disable log category NetworkInstanceUpdates"
      },
      "defaultValue": true
    },
    "systemsessionhistoryupdatesEnabled": {
      "type": "bool",
      "metadata": {
        "displayName": "SystemSessionHistoryUpdates",
        "description": "Enable or disable log category SystemSessionHistoryUpdates"
      },
      "defaultValue": true
    },
    "systemstatemessageupdatesEnabled": {
      "type": "bool",
      "metadata": {
        "displayName": "SystemStateMessageUpdates",
        "description": "Enable or disable log category SystemStateMessageUpdates"
      },
      "defaultValue": true
    }
  },
  "policyRule": {
    "if": {
      "allOf": [
        {
          "field": "type",
          "equals": "Microsoft.ManagedNetworkFabric/networkDevices"
        },
        {
          "anyOf": [
            {
              "value": "[first(parameters('resourceLocationList'))]",
              "equals": "*"
            },
            {
              "field": "location",
              "in": "[parameters('resourceLocationList')]"
            }
          ]
        }
      ]
    },
    "then": {
      "effect": "[parameters('effect')]",
      "details": {
        "type": "Microsoft.Insights/diagnosticSettings",
        "existenceCondition": {
          "allOf": [
            {
              "count": {
                "field": "Microsoft.Insights/diagnosticSettings/logs[*]",
                "where": {
                  "anyOf": [
                    {
                      "field": "Microsoft.Insights/diagnosticSettings/logs[*].enabled",
                      "equals": true
                    }
                  ]
                }
              },
              "greaterOrEquals": 1
            },
            {
              "field": "Microsoft.Insights/diagnosticSettings/marketplacePartnerId",
              "equals": "[parameters('dynatraceResource')]"
            }
          ]
        },
        "deployment": {
          "properties": {
            "mode": "incremental",
            "template": {
              "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
              "contentVersion": "1.0.0.0",
              "parameters": {
                "resourceName": {
                  "type": "string"
                },
                "diagnosticSettingName": {
                  "type": "string"
                },
                "dynatraceResource": {
                  "type": "string"
                },
                "logs": {
                  "type": "array"
                }
              },
              "variables": {},
              "resources": [
                {
                  "type": "Microsoft.ManagedNetworkFabric/networkDevices/providers/diagnosticSettings",
                  "apiVersion": "2021-05-01-preview",
                  "name": "[concat(parameters('resourceName'), '/', parameters('diagnosticSettingName'))]",
                  "properties": {
                    "workspaceId": "[parameters('dynatraceResource')]",
                    "logs": "[parameters('logs')]"
                  }
                }
              ],
              "outputs": {
                "policy": {
                  "type": "string",
                  "value": "[concat('Diagnostic setting ', parameters('diagnosticSettingName'), ' for type Microsoft.ManagedNetworkFabric/networkDevices, resourceName ', parameters('resourceName'), ' to Azure Native Dynatrace Service ', parameters('dynatraceResource'), ' configured')]"
                }
              }
            },
            "parameters": {
              "resourceName": {
                "value": "[field('name')]"
              },
              "diagnosticSettingName": {
                "value": "[parameters('diagnosticSettingName')]"
              },
              "dynatraceResource": {
                "value": "[parameters('dynatraceResource')]"
              },
              "logs": {
                "value": [
                  {
                    "category": "BfdStateUpdates",
                    "enabled": "[parameters('bfdstateupdatesEnabled')]"
                  },
                  {
                    "category": "ComponentStateUpdates",
                    "enabled": "[parameters('componentstateupdatesEnabled')]"
                  },
                  {
                    "category": "InterfaceStateUpdates",
                    "enabled": "[parameters('interfacestateupdatesEnabled')]"
                  },
                  {
                    "category": "InterfaceVxlanUpdates",
                    "enabled": "[parameters('interfacevxlanupdatesEnabled')]"
                  },
                  {
                    "category": "NetworkInstanceBgpNeighborUpdates",
                    "enabled": "[parameters('networkinstancebgpneighborupdatesEnabled')]"
                  },
                  {
                    "category": "NetworkInstanceUpdates",
                    "enabled": "[parameters('networkinstanceupdatesEnabled')]"
                  },
                  {
                    "category": "SystemSessionHistoryUpdates",
                    "enabled": "[parameters('systemsessionhistoryupdatesEnabled')]"
                  },
                  {
                    "category": "SystemStateMessageUpdates",
                    "enabled": "[parameters('systemstatemessageupdatesEnabled')]"
                  }
                ]
              }
            }
          }
        }
      }
    }
  }
}
