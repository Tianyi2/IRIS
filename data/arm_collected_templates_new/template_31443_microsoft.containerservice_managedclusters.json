{
  "properties": {
    "displayName": "Deploy Diagnostic Settings for Microsoft.ContainerService/managedClusters to Azure Native Dynatrace Service",
    "policyType": "Custom",
    "mode": "Indexed",
    "version": "1.0.0",
    "description": "This policy enables diagnostic settings for Microsoft.ContainerService/managedClusters to send all available logs to a Dynatrace environment.",
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Enable or disable the execution of the policy"
        },
        "allowedValues": [
          "DeployIfNotExists",
          "AuditIfNotExists",
          "Disabled"
        ],
        "defaultValue": "DeployIfNotExists"
      },
      "diagnosticSettingName": {
        "type": "String",
        "metadata": {
          "displayName": "Diagnostic Setting Name",
          "description": "The name of the diagnostic setting to create."
        },
        "defaultValue": "setByPolicy-Dynatrace"
      },
      "resourceLocationList": {
        "type": "Array",
        "metadata": {
          "displayName": "Resource Location List",
          "description": "List of resource locations to which this policy is applied."
        },
        "defaultValue": [
          "*"
        ]
      },
      "dynatraceResource": {
        "type": "String",
        "metadata": {
          "displayName": "Azure Native Dynatrace Service",
          "description": "Azure Native Dynatrace Service resource id",
          "strongType": "Dynatrace.Observability/monitors",
          "assignPermissions": true
        }
      }
    },
    "cloudcontrollermanagerEnabled": {
      "type": "bool",
      "metadata": {
        "displayName": "cloud-controller-manager",
        "description": "Enable or disable log category cloud-controller-manager"
      },
      "defaultValue": true
    },
    "clusterautoscalerEnabled": {
      "type": "bool",
      "metadata": {
        "displayName": "cluster-autoscaler",
        "description": "Enable or disable log category cluster-autoscaler"
      },
      "defaultValue": true
    },
    "csiazurediskcontrollerEnabled": {
      "type": "bool",
      "metadata": {
        "displayName": "csi-azuredisk-controller",
        "description": "Enable or disable log category csi-azuredisk-controller"
      },
      "defaultValue": true
    },
    "csiazurefilecontrollerEnabled": {
      "type": "bool",
      "metadata": {
        "displayName": "csi-azurefile-controller",
        "description": "Enable or disable log category csi-azurefile-controller"
      },
      "defaultValue": true
    },
    "csisnapshotcontrollerEnabled": {
      "type": "bool",
      "metadata": {
        "displayName": "csi-snapshot-controller",
        "description": "Enable or disable log category csi-snapshot-controller"
      },
      "defaultValue": true
    },
    "fleetmcscontrollermanagerEnabled": {
      "type": "bool",
      "metadata": {
        "displayName": "fleet-mcs-controller-manager",
        "description": "Enable or disable log category fleet-mcs-controller-manager"
      },
      "defaultValue": true
    },
    "fleetmemberagentEnabled": {
      "type": "bool",
      "metadata": {
        "displayName": "fleet-member-agent",
        "description": "Enable or disable log category fleet-member-agent"
      },
      "defaultValue": true
    },
    "fleetmembernetcontrollermanagerEnabled": {
      "type": "bool",
      "metadata": {
        "displayName": "fleet-member-net-controller-manager",
        "description": "Enable or disable log category fleet-member-net-controller-manager"
      },
      "defaultValue": true
    },
    "guardEnabled": {
      "type": "bool",
      "metadata": {
        "displayName": "guard",
        "description": "Enable or disable log category guard"
      },
      "defaultValue": true
    },
    "kubeapiserverEnabled": {
      "type": "bool",
      "metadata": {
        "displayName": "kube-apiserver",
        "description": "Enable or disable log category kube-apiserver"
      },
      "defaultValue": true
    },
    "kubeauditEnabled": {
      "type": "bool",
      "metadata": {
        "displayName": "kube-audit",
        "description": "Enable or disable log category kube-audit"
      },
      "defaultValue": true
    },
    "kubeauditadminEnabled": {
      "type": "bool",
      "metadata": {
        "displayName": "kube-audit-admin",
        "description": "Enable or disable log category kube-audit-admin"
      },
      "defaultValue": true
    },
    "kubecontrollermanagerEnabled": {
      "type": "bool",
      "metadata": {
        "displayName": "kube-controller-manager",
        "description": "Enable or disable log category kube-controller-manager"
      },
      "defaultValue": true
    },
    "kubeschedulerEnabled": {
      "type": "bool",
      "metadata": {
        "displayName": "kube-scheduler",
        "description": "Enable or disable log category kube-scheduler"
      },
      "defaultValue": true
    }
  },
  "policyRule": {
    "if": {
      "allOf": [
        {
          "field": "type",
          "equals": "Microsoft.ContainerService/managedClusters"
        },
        {
          "anyOf": [
            {
              "value": "[first(parameters('resourceLocationList'))]",
              "equals": "*"
            },
            {
              "field": "location",
              "in": "[parameters('resourceLocationList')]"
            }
          ]
        }
      ]
    },
    "then": {
      "effect": "[parameters('effect')]",
      "details": {
        "type": "Microsoft.Insights/diagnosticSettings",
        "existenceCondition": {
          "allOf": [
            {
              "count": {
                "field": "Microsoft.Insights/diagnosticSettings/logs[*]",
                "where": {
                  "anyOf": [
                    {
                      "field": "Microsoft.Insights/diagnosticSettings/logs[*].enabled",
                      "equals": true
                    }
                  ]
                }
              },
              "greaterOrEquals": 1
            },
            {
              "field": "Microsoft.Insights/diagnosticSettings/marketplacePartnerId",
              "equals": "[parameters('dynatraceResource')]"
            }
          ]
        },
        "deployment": {
          "properties": {
            "mode": "incremental",
            "template": {
              "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
              "contentVersion": "1.0.0.0",
              "parameters": {
                "resourceName": {
                  "type": "string"
                },
                "diagnosticSettingName": {
                  "type": "string"
                },
                "dynatraceResource": {
                  "type": "string"
                },
                "logs": {
                  "type": "array"
                }
              },
              "variables": {},
              "resources": [
                {
                  "type": "Microsoft.ContainerService/managedClusters/providers/diagnosticSettings",
                  "apiVersion": "2021-05-01-preview",
                  "name": "[concat(parameters('resourceName'), '/', parameters('diagnosticSettingName'))]",
                  "properties": {
                    "workspaceId": "[parameters('dynatraceResource')]",
                    "logs": "[parameters('logs')]"
                  }
                }
              ],
              "outputs": {
                "policy": {
                  "type": "string",
                  "value": "[concat('Diagnostic setting ', parameters('diagnosticSettingName'), ' for type Microsoft.ContainerService/managedClusters, resourceName ', parameters('resourceName'), ' to Azure Native Dynatrace Service ', parameters('dynatraceResource'), ' configured')]"
                }
              }
            },
            "parameters": {
              "resourceName": {
                "value": "[field('name')]"
              },
              "diagnosticSettingName": {
                "value": "[parameters('diagnosticSettingName')]"
              },
              "dynatraceResource": {
                "value": "[parameters('dynatraceResource')]"
              },
              "logs": {
                "value": [
                  {
                    "category": "cloud-controller-manager",
                    "enabled": "[parameters('cloudcontrollermanagerEnabled')]"
                  },
                  {
                    "category": "cluster-autoscaler",
                    "enabled": "[parameters('clusterautoscalerEnabled')]"
                  },
                  {
                    "category": "csi-azuredisk-controller",
                    "enabled": "[parameters('csiazurediskcontrollerEnabled')]"
                  },
                  {
                    "category": "csi-azurefile-controller",
                    "enabled": "[parameters('csiazurefilecontrollerEnabled')]"
                  },
                  {
                    "category": "csi-snapshot-controller",
                    "enabled": "[parameters('csisnapshotcontrollerEnabled')]"
                  },
                  {
                    "category": "fleet-mcs-controller-manager",
                    "enabled": "[parameters('fleetmcscontrollermanagerEnabled')]"
                  },
                  {
                    "category": "fleet-member-agent",
                    "enabled": "[parameters('fleetmemberagentEnabled')]"
                  },
                  {
                    "category": "fleet-member-net-controller-manager",
                    "enabled": "[parameters('fleetmembernetcontrollermanagerEnabled')]"
                  },
                  {
                    "category": "guard",
                    "enabled": "[parameters('guardEnabled')]"
                  },
                  {
                    "category": "kube-apiserver",
                    "enabled": "[parameters('kubeapiserverEnabled')]"
                  },
                  {
                    "category": "kube-audit",
                    "enabled": "[parameters('kubeauditEnabled')]"
                  },
                  {
                    "category": "kube-audit-admin",
                    "enabled": "[parameters('kubeauditadminEnabled')]"
                  },
                  {
                    "category": "kube-controller-manager",
                    "enabled": "[parameters('kubecontrollermanagerEnabled')]"
                  },
                  {
                    "category": "kube-scheduler",
                    "enabled": "[parameters('kubeschedulerEnabled')]"
                  }
                ]
              }
            }
          }
        }
      }
    }
  }
}
