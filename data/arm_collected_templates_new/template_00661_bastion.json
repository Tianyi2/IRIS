{
  "$schema":"https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "languageVersion":"2.0",
  "contentVersion":"1.1.1.1",
  "apiProfile":"",
  "definitions":{},
  "parameters":{
    "environment":{
      "defaultValue":"stg",
      "type":"String",
      "metadata":{
        "description":"Environment."
      }
    },
    "region_name":{
      "defaultValue":"[resourceGroup().location]",
      "type":"String",
      "metadata":{
        "description":"Region name."
      }
    },
    "virtual_network_name":{
      "defaultValue":"vnet",
      "type":"String",
      "metadata":{
        "description":"Virtual network name."
      }
    },
    "network_security_group_name":{
      "defaultValue":"bastion-nsg",
      "type":"String",
      "metadata":{
        "description":"Network security group name."
      }
    },
    "image_name":{
      "defaultValue":"sloopstash-alma-linux-9-v1.1.1-img",
      "type":"String",
      "metadata":{
        "description":"Image name."
      }
    }
  },
  "variables":{},
  "functions":[],
  "resources":{
    "bastion_ni_1":{
      "apiVersion":"2021-05-01",
      "type":"Microsoft.Network/networkInterfaces",
      "name":"bastion-ni-1",
      "location":"[parameters('region_name')]",
      "properties":{
        "ipConfigurations":[{
          "name":"ip-addr-1",
            "properties":{
              "subnet":{
                "id":"[resourceId('Microsoft.Network/virtualNetworks/subnets',parameters('virtual_network_name'),'vnet-bastion-sn-1')]"
              },
              "privateIPAllocationMethod":"Static",
              "privateIPAddress":"12.1.5.10",
              "privateIPAddressVersion":"IPv4",
              "publicIPAddress":{
                "id":"[resourceId('Microsoft.Network/publicIPAddresses','bastion-pip')]"
              }
            }
          }
        ],
        "networkSecurityGroup": {
          "id":"[resourceId('Microsoft.Network/networkSecurityGroups',parameters('network_security_group_name'))]"
        }
      },
      "tags":{
        "Name":"bastion-ni-1",
        "Environment":"[parameters('environment')]",
        "Region":"[parameters('region_name')]",
        "Organization":"sloopstash"
      }
    },
    "bastion_vm_1":{
      "apiVersion":"2023-03-01",
      "type":"Microsoft.Compute/virtualMachines",
      "dependsOn":["bastion_ni_1"],
      "name":"bastion-vm-1",
      "location":"[parameters('region_name')]",
      "properties":{
        "hardwareProfile":{
          "vmSize":"Standard_B1s"
        },
        "storageProfile":{
          "osDisk":{
            "osType":"Linux",
            "name":"bastion-dsk-1",
            "createOption":"FromImage",
            "caching":"ReadWrite",
            "diskSizeGB":30,
            "managedDisk":{
              "storageAccountType":"Standard_LRS"
            },
            "deleteOption":"Delete"
          },
          "imageReference":{
            "id":"[resourceId('Microsoft.Compute/images',parameters('image_name'))]"
          }
        },
        "networkProfile":{
          "networkInterfaces":[{
            "id":"[resourceId('Microsoft.Network/networkInterfaces','bastion-ni-1')]",
            "properties":{
              "deleteOption":"Delete"
            }
          }]
        },
        "osProfile":{
          "computerName":"bastion-vm-1",
          "AdminUsername":"azureuser",
          "linuxConfiguration":{
            "disablePasswordAuthentication":true,
            "ssh":{
              "publicKeys":[{
                "path":"/home/azureuser/.ssh/authorized_keys",
                "keyData":"[reference(resourceId('Microsoft.Compute/sshPublicKeys','rsa-sk'),'2019-12-01').publicKey]"
              }]
            }
          }
        }
      },
      "tags":{
        "Name":"bastion-vm-1",
        "Environment":"[parameters('environment')]",
        "Region":"[parameters('region_name')]",
        "Organization":"sloopstash"
      }
    }
  },
  "outputs":{}
}
