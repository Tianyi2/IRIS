{
  "properties": {
    "displayName": "Deploy Diagnostic Settings for Microsoft.AgFoodPlatform/farmBeats to Azure Native Dynatrace Service",
    "policyType": "Custom",
    "mode": "Indexed",
    "version": "1.0.0",
    "description": "This policy enables diagnostic settings for Microsoft.AgFoodPlatform/farmBeats to send all available logs to a Dynatrace environment.",
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Enable or disable the execution of the policy"
        },
        "allowedValues": [
          "DeployIfNotExists",
          "AuditIfNotExists",
          "Disabled"
        ],
        "defaultValue": "DeployIfNotExists"
      },
      "diagnosticSettingName": {
        "type": "String",
        "metadata": {
          "displayName": "Diagnostic Setting Name",
          "description": "The name of the diagnostic setting to create."
        },
        "defaultValue": "setByPolicy-Dynatrace"
      },
      "resourceLocationList": {
        "type": "Array",
        "metadata": {
          "displayName": "Resource Location List",
          "description": "List of resource locations to which this policy is applied."
        },
        "defaultValue": [
          "*"
        ]
      },
      "dynatraceResource": {
        "type": "String",
        "metadata": {
          "displayName": "Azure Native Dynatrace Service",
          "description": "Azure Native Dynatrace Service resource id",
          "strongType": "Dynatrace.Observability/monitors",
          "assignPermissions": true
        }
      }
    },
    "applicationauditlogsEnabled": {
      "type": "bool",
      "metadata": {
        "displayName": "ApplicationAuditLogs",
        "description": "Enable or disable log category ApplicationAuditLogs"
      },
      "defaultValue": true
    },
    "farmmanagementlogsEnabled": {
      "type": "bool",
      "metadata": {
        "displayName": "FarmManagementLogs",
        "description": "Enable or disable log category FarmManagementLogs"
      },
      "defaultValue": true
    },
    "farmoperationlogsEnabled": {
      "type": "bool",
      "metadata": {
        "displayName": "FarmOperationLogs",
        "description": "Enable or disable log category FarmOperationLogs"
      },
      "defaultValue": true
    },
    "insightlogsEnabled": {
      "type": "bool",
      "metadata": {
        "displayName": "InsightLogs",
        "description": "Enable or disable log category InsightLogs"
      },
      "defaultValue": true
    },
    "jobprocessedlogsEnabled": {
      "type": "bool",
      "metadata": {
        "displayName": "JobProcessedLogs",
        "description": "Enable or disable log category JobProcessedLogs"
      },
      "defaultValue": true
    },
    "modelinferencelogsEnabled": {
      "type": "bool",
      "metadata": {
        "displayName": "ModelInferenceLogs",
        "description": "Enable or disable log category ModelInferenceLogs"
      },
      "defaultValue": true
    },
    "providerauthlogsEnabled": {
      "type": "bool",
      "metadata": {
        "displayName": "ProviderAuthLogs",
        "description": "Enable or disable log category ProviderAuthLogs"
      },
      "defaultValue": true
    },
    "satellitelogsEnabled": {
      "type": "bool",
      "metadata": {
        "displayName": "SatelliteLogs",
        "description": "Enable or disable log category SatelliteLogs"
      },
      "defaultValue": true
    },
    "sensormanagementlogsEnabled": {
      "type": "bool",
      "metadata": {
        "displayName": "SensorManagementLogs",
        "description": "Enable or disable log category SensorManagementLogs"
      },
      "defaultValue": true
    },
    "weatherlogsEnabled": {
      "type": "bool",
      "metadata": {
        "displayName": "WeatherLogs",
        "description": "Enable or disable log category WeatherLogs"
      },
      "defaultValue": true
    }
  },
  "policyRule": {
    "if": {
      "allOf": [
        {
          "field": "type",
          "equals": "Microsoft.AgFoodPlatform/farmBeats"
        },
        {
          "anyOf": [
            {
              "value": "[first(parameters('resourceLocationList'))]",
              "equals": "*"
            },
            {
              "field": "location",
              "in": "[parameters('resourceLocationList')]"
            }
          ]
        }
      ]
    },
    "then": {
      "effect": "[parameters('effect')]",
      "details": {
        "type": "Microsoft.Insights/diagnosticSettings",
        "existenceCondition": {
          "allOf": [
            {
              "count": {
                "field": "Microsoft.Insights/diagnosticSettings/logs[*]",
                "where": {
                  "anyOf": [
                    {
                      "field": "Microsoft.Insights/diagnosticSettings/logs[*].enabled",
                      "equals": true
                    }
                  ]
                }
              },
              "greaterOrEquals": 1
            },
            {
              "field": "Microsoft.Insights/diagnosticSettings/marketplacePartnerId",
              "equals": "[parameters('dynatraceResource')]"
            }
          ]
        },
        "deployment": {
          "properties": {
            "mode": "incremental",
            "template": {
              "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
              "contentVersion": "1.0.0.0",
              "parameters": {
                "resourceName": {
                  "type": "string"
                },
                "diagnosticSettingName": {
                  "type": "string"
                },
                "dynatraceResource": {
                  "type": "string"
                },
                "logs": {
                  "type": "array"
                }
              },
              "variables": {},
              "resources": [
                {
                  "type": "Microsoft.AgFoodPlatform/farmBeats/providers/diagnosticSettings",
                  "apiVersion": "2021-05-01-preview",
                  "name": "[concat(parameters('resourceName'), '/', parameters('diagnosticSettingName'))]",
                  "properties": {
                    "workspaceId": "[parameters('dynatraceResource')]",
                    "logs": "[parameters('logs')]"
                  }
                }
              ],
              "outputs": {
                "policy": {
                  "type": "string",
                  "value": "[concat('Diagnostic setting ', parameters('diagnosticSettingName'), ' for type Microsoft.AgFoodPlatform/farmBeats, resourceName ', parameters('resourceName'), ' to Azure Native Dynatrace Service ', parameters('dynatraceResource'), ' configured')]"
                }
              }
            },
            "parameters": {
              "resourceName": {
                "value": "[field('name')]"
              },
              "diagnosticSettingName": {
                "value": "[parameters('diagnosticSettingName')]"
              },
              "dynatraceResource": {
                "value": "[parameters('dynatraceResource')]"
              },
              "logs": {
                "value": [
                  {
                    "category": "ApplicationAuditLogs",
                    "enabled": "[parameters('applicationauditlogsEnabled')]"
                  },
                  {
                    "category": "FarmManagementLogs",
                    "enabled": "[parameters('farmmanagementlogsEnabled')]"
                  },
                  {
                    "category": "FarmOperationLogs",
                    "enabled": "[parameters('farmoperationlogsEnabled')]"
                  },
                  {
                    "category": "InsightLogs",
                    "enabled": "[parameters('insightlogsEnabled')]"
                  },
                  {
                    "category": "JobProcessedLogs",
                    "enabled": "[parameters('jobprocessedlogsEnabled')]"
                  },
                  {
                    "category": "ModelInferenceLogs",
                    "enabled": "[parameters('modelinferencelogsEnabled')]"
                  },
                  {
                    "category": "ProviderAuthLogs",
                    "enabled": "[parameters('providerauthlogsEnabled')]"
                  },
                  {
                    "category": "SatelliteLogs",
                    "enabled": "[parameters('satellitelogsEnabled')]"
                  },
                  {
                    "category": "SensorManagementLogs",
                    "enabled": "[parameters('sensormanagementlogsEnabled')]"
                  },
                  {
                    "category": "WeatherLogs",
                    "enabled": "[parameters('weatherlogsEnabled')]"
                  }
                ]
              }
            }
          }
        }
      }
    }
  }
}
