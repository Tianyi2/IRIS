{
  "properties": {
    "displayName": "Deploy Diagnostic Settings for Microsoft.Web/sites to Azure Native Dynatrace Service",
    "policyType": "Custom",
    "mode": "Indexed",
    "version": "1.0.0",
    "description": "This policy enables diagnostic settings for Microsoft.Web/sites to send all available logs to a Dynatrace environment.",
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Enable or disable the execution of the policy"
        },
        "allowedValues": [
          "DeployIfNotExists",
          "AuditIfNotExists",
          "Disabled"
        ],
        "defaultValue": "DeployIfNotExists"
      },
      "diagnosticSettingName": {
        "type": "String",
        "metadata": {
          "displayName": "Diagnostic Setting Name",
          "description": "The name of the diagnostic setting to create."
        },
        "defaultValue": "setByPolicy-Dynatrace"
      },
      "resourceLocationList": {
        "type": "Array",
        "metadata": {
          "displayName": "Resource Location List",
          "description": "List of resource locations to which this policy is applied."
        },
        "defaultValue": [
          "*"
        ]
      },
      "dynatraceResource": {
        "type": "String",
        "metadata": {
          "displayName": "Azure Native Dynatrace Service",
          "description": "Azure Native Dynatrace Service resource id",
          "strongType": "Dynatrace.Observability/monitors",
          "assignPermissions": true
        }
      }
    },
    "appserviceantivirusscanauditlogsEnabled": {
      "type": "bool",
      "metadata": {
        "displayName": "AppServiceAntivirusScanAuditLogs",
        "description": "Enable or disable log category AppServiceAntivirusScanAuditLogs"
      },
      "defaultValue": true
    },
    "appserviceapplogsEnabled": {
      "type": "bool",
      "metadata": {
        "displayName": "AppServiceAppLogs",
        "description": "Enable or disable log category AppServiceAppLogs"
      },
      "defaultValue": true
    },
    "appserviceauditlogsEnabled": {
      "type": "bool",
      "metadata": {
        "displayName": "AppServiceAuditLogs",
        "description": "Enable or disable log category AppServiceAuditLogs"
      },
      "defaultValue": true
    },
    "appserviceauthenticationlogsEnabled": {
      "type": "bool",
      "metadata": {
        "displayName": "AppServiceAuthenticationLogs",
        "description": "Enable or disable log category AppServiceAuthenticationLogs"
      },
      "defaultValue": true
    },
    "appserviceconsolelogsEnabled": {
      "type": "bool",
      "metadata": {
        "displayName": "AppServiceConsoleLogs",
        "description": "Enable or disable log category AppServiceConsoleLogs"
      },
      "defaultValue": true
    },
    "appservicefileauditlogsEnabled": {
      "type": "bool",
      "metadata": {
        "displayName": "AppServiceFileAuditLogs",
        "description": "Enable or disable log category AppServiceFileAuditLogs"
      },
      "defaultValue": true
    },
    "appservicehttplogsEnabled": {
      "type": "bool",
      "metadata": {
        "displayName": "AppServiceHTTPLogs",
        "description": "Enable or disable log category AppServiceHTTPLogs"
      },
      "defaultValue": true
    },
    "appserviceipsecauditlogsEnabled": {
      "type": "bool",
      "metadata": {
        "displayName": "AppServiceIPSecAuditLogs",
        "description": "Enable or disable log category AppServiceIPSecAuditLogs"
      },
      "defaultValue": true
    },
    "appserviceplatformlogsEnabled": {
      "type": "bool",
      "metadata": {
        "displayName": "AppServicePlatformLogs",
        "description": "Enable or disable log category AppServicePlatformLogs"
      },
      "defaultValue": true
    },
    "functionapplogsEnabled": {
      "type": "bool",
      "metadata": {
        "displayName": "FunctionAppLogs",
        "description": "Enable or disable log category FunctionAppLogs"
      },
      "defaultValue": true
    },
    "workflowruntimeEnabled": {
      "type": "bool",
      "metadata": {
        "displayName": "WorkflowRuntime",
        "description": "Enable or disable log category WorkflowRuntime"
      },
      "defaultValue": true
    }
  },
  "policyRule": {
    "if": {
      "allOf": [
        {
          "field": "type",
          "equals": "Microsoft.Web/sites"
        },
        {
          "anyOf": [
            {
              "value": "[first(parameters('resourceLocationList'))]",
              "equals": "*"
            },
            {
              "field": "location",
              "in": "[parameters('resourceLocationList')]"
            }
          ]
        }
      ]
    },
    "then": {
      "effect": "[parameters('effect')]",
      "details": {
        "type": "Microsoft.Insights/diagnosticSettings",
        "existenceCondition": {
          "allOf": [
            {
              "count": {
                "field": "Microsoft.Insights/diagnosticSettings/logs[*]",
                "where": {
                  "anyOf": [
                    {
                      "field": "Microsoft.Insights/diagnosticSettings/logs[*].enabled",
                      "equals": true
                    }
                  ]
                }
              },
              "greaterOrEquals": 1
            },
            {
              "field": "Microsoft.Insights/diagnosticSettings/marketplacePartnerId",
              "equals": "[parameters('dynatraceResource')]"
            }
          ]
        },
        "deployment": {
          "properties": {
            "mode": "incremental",
            "template": {
              "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
              "contentVersion": "1.0.0.0",
              "parameters": {
                "resourceName": {
                  "type": "string"
                },
                "diagnosticSettingName": {
                  "type": "string"
                },
                "dynatraceResource": {
                  "type": "string"
                },
                "logs": {
                  "type": "array"
                }
              },
              "variables": {},
              "resources": [
                {
                  "type": "Microsoft.Web/sites/providers/diagnosticSettings",
                  "apiVersion": "2021-05-01-preview",
                  "name": "[concat(parameters('resourceName'), '/', parameters('diagnosticSettingName'))]",
                  "properties": {
                    "workspaceId": "[parameters('dynatraceResource')]",
                    "logs": "[parameters('logs')]"
                  }
                }
              ],
              "outputs": {
                "policy": {
                  "type": "string",
                  "value": "[concat('Diagnostic setting ', parameters('diagnosticSettingName'), ' for type Microsoft.Web/sites, resourceName ', parameters('resourceName'), ' to Azure Native Dynatrace Service ', parameters('dynatraceResource'), ' configured')]"
                }
              }
            },
            "parameters": {
              "resourceName": {
                "value": "[field('name')]"
              },
              "diagnosticSettingName": {
                "value": "[parameters('diagnosticSettingName')]"
              },
              "dynatraceResource": {
                "value": "[parameters('dynatraceResource')]"
              },
              "logs": {
                "value": [
                  {
                    "category": "AppServiceAntivirusScanAuditLogs",
                    "enabled": "[parameters('appserviceantivirusscanauditlogsEnabled')]"
                  },
                  {
                    "category": "AppServiceAppLogs",
                    "enabled": "[parameters('appserviceapplogsEnabled')]"
                  },
                  {
                    "category": "AppServiceAuditLogs",
                    "enabled": "[parameters('appserviceauditlogsEnabled')]"
                  },
                  {
                    "category": "AppServiceAuthenticationLogs",
                    "enabled": "[parameters('appserviceauthenticationlogsEnabled')]"
                  },
                  {
                    "category": "AppServiceConsoleLogs",
                    "enabled": "[parameters('appserviceconsolelogsEnabled')]"
                  },
                  {
                    "category": "AppServiceFileAuditLogs",
                    "enabled": "[parameters('appservicefileauditlogsEnabled')]"
                  },
                  {
                    "category": "AppServiceHTTPLogs",
                    "enabled": "[parameters('appservicehttplogsEnabled')]"
                  },
                  {
                    "category": "AppServiceIPSecAuditLogs",
                    "enabled": "[parameters('appserviceipsecauditlogsEnabled')]"
                  },
                  {
                    "category": "AppServicePlatformLogs",
                    "enabled": "[parameters('appserviceplatformlogsEnabled')]"
                  },
                  {
                    "category": "FunctionAppLogs",
                    "enabled": "[parameters('functionapplogsEnabled')]"
                  },
                  {
                    "category": "WorkflowRuntime",
                    "enabled": "[parameters('workflowruntimeEnabled')]"
                  }
                ]
              }
            }
          }
        }
      }
    }
  }
}
