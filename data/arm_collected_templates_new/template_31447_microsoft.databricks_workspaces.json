  },
  "policyRule": {
    "if": {
      "allOf": [
        {
          "field": "type",
          "equals": "Microsoft.Databricks/workspaces"
        },
        {
          "anyOf": [
            {
              "value": "[first(parameters('resourceLocationList'))]",
              "equals": "*"
            },
            {
              "field": "location",
              "in": "[parameters('resourceLocationList')]"
            }
          ]
        }
      ]
    },
    "then": {
      "effect": "[parameters('effect')]",
      "details": {
        "type": "Microsoft.Insights/diagnosticSettings",
        "existenceCondition": {
          "allOf": [
            {
              "count": {
                "field": "Microsoft.Insights/diagnosticSettings/logs[*]",
                "where": {
                  "anyOf": [
                    {
                      "field": "Microsoft.Insights/diagnosticSettings/logs[*].enabled",
                      "equals": true
                    }
                  ]
                }
              },
              "greaterOrEquals": 1
            },
            {
              "field": "Microsoft.Insights/diagnosticSettings/marketplacePartnerId",
              "equals": "[parameters('dynatraceResource')]"
            }
          ]
        },
        "deployment": {
          "properties": {
            "mode": "incremental",
            "template": {
              "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
              "contentVersion": "1.0.0.0",
              "parameters": {
                "resourceName": {
                  "type": "string"
                },
                "diagnosticSettingName": {
                  "type": "string"
                },
                "dynatraceResource": {
                  "type": "string"
                },
                "logs": {
                  "type": "array"
                }
              },
              "variables": {},
              "resources": [
                {
                  "type": "Microsoft.Databricks/workspaces/providers/diagnosticSettings",
                  "apiVersion": "2021-05-01-preview",
                  "name": "[concat(parameters('resourceName'), '/', parameters('diagnosticSettingName'))]",
                  "properties": {
                    "workspaceId": "[parameters('dynatraceResource')]",
                    "logs": "[parameters('logs')]"
                  }
                }
              ],
              "outputs": {
                "policy": {
                  "type": "string",
                  "value": "[concat('Diagnostic setting ', parameters('diagnosticSettingName'), ' for type Microsoft.Databricks/workspaces, resourceName ', parameters('resourceName'), ' to Azure Native Dynatrace Service ', parameters('dynatraceResource'), ' configured')]"
                }
              }
            },
            "parameters": {
              "resourceName": {
                "value": "[field('name')]"
              },
              "diagnosticSettingName": {
                "value": "[parameters('diagnosticSettingName')]"
              },
              "dynatraceResource": {
                "value": "[parameters('dynatraceResource')]"
              },
              "logs": {
                "value": [
                  {
                    "category": "accounts",
                    "enabled": "[parameters('accountsEnabled')]"
                  },
                  {
                    "category": "Apps",
                    "enabled": "[parameters('appsEnabled')]"
                  },
                  {
                    "category": "BrickStoreHttpGateway",
                    "enabled": "[parameters('brickstorehttpgatewayEnabled')]"
                  },
                  {
                    "category": "BudgetPolicyCentral",
                    "enabled": "[parameters('budgetpolicycentralEnabled')]"
                  },
                  {
                    "category": "capsule8Dataplane",
                    "enabled": "[parameters('capsule8dataplaneEnabled')]"
                  },
                  {
                    "category": "clamAVScan",
                    "enabled": "[parameters('clamavscanEnabled')]"
                  },
                  {
                    "category": "CloudStorageMetadata",
                    "enabled": "[parameters('cloudstoragemetadataEnabled')]"
                  },
                  {
                    "category": "clusterLibraries",
                    "enabled": "[parameters('clusterlibrariesEnabled')]"
                  },
                  {
                    "category": "ClusterPolicies",
                    "enabled": "[parameters('clusterpoliciesEnabled')]"
                  },
                  {
                    "category": "clusters",
                    "enabled": "[parameters('clustersEnabled')]"
                  },
                  {
                    "category": "Dashboards",
                    "enabled": "[parameters('dashboardsEnabled')]"
                  },
                  {
                    "category": "databrickssql",
                    "enabled": "[parameters('databrickssqlEnabled')]"
                  },
                  {
                    "category": "DataMonitoring",
                    "enabled": "[parameters('datamonitoringEnabled')]"
                  },
                  {
                    "category": "DataRooms",
                    "enabled": "[parameters('dataroomsEnabled')]"
                  },
                  {
                    "category": "dbfs",
                    "enabled": "[parameters('dbfsEnabled')]"
                  },
                  {
                    "category": "deltaPipelines",
                    "enabled": "[parameters('deltapipelinesEnabled')]"
                  },
                  {
                    "category": "featureStore",
                    "enabled": "[parameters('featurestoreEnabled')]"
                  },
                  {
                    "category": "Files",
                    "enabled": "[parameters('filesEnabled')]"
                  },
                  {
                    "category": "Filesystem",
                    "enabled": "[parameters('filesystemEnabled')]"
                  },
                  {
                    "category": "genie",
                    "enabled": "[parameters('genieEnabled')]"
                  },
                  {
                    "category": "gitCredentials",
                    "enabled": "[parameters('gitcredentialsEnabled')]"
                  },
                  {
                    "category": "globalInitScripts",
                    "enabled": "[parameters('globalinitscriptsEnabled')]"
                  },
                  {
                    "category": "Groups",
                    "enabled": "[parameters('groupsEnabled')]"
                  },
                  {
                    "category": "iamRole",
                    "enabled": "[parameters('iamroleEnabled')]"
                  },
                  {
                    "category": "Ingestion",
                    "enabled": "[parameters('ingestionEnabled')]"
                  },
                  {
                    "category": "instancePools",
                    "enabled": "[parameters('instancepoolsEnabled')]"
                  },
                  {
                    "category": "jobs",
                    "enabled": "[parameters('jobsEnabled')]"
                  },
                  {
                    "category": "LakeviewConfig",
                    "enabled": "[parameters('lakeviewconfigEnabled')]"
                  },
                  {
                    "category": "LineageTracking",
                    "enabled": "[parameters('lineagetrackingEnabled')]"
                  },
                  {
                    "category": "MarketplaceConsumer",
                    "enabled": "[parameters('marketplaceconsumerEnabled')]"
                  },
                  {
                    "category": "MarketplaceProvider",
                    "enabled": "[parameters('marketplaceproviderEnabled')]"
                  },
                  {
                    "category": "mlflowAcledArtifact",
                    "enabled": "[parameters('mlflowacledartifactEnabled')]"
                  },
                  {
                    "category": "mlflowExperiment",
                    "enabled": "[parameters('mlflowexperimentEnabled')]"
                  },
                  {
                    "category": "modelRegistry",
                    "enabled": "[parameters('modelregistryEnabled')]"
                  },
                  {
                    "category": "notebook",
                    "enabled": "[parameters('notebookEnabled')]"
                  },
                  {
                    "category": "OnlineTables",
                    "enabled": "[parameters('onlinetablesEnabled')]"
                  },
                  {
                    "category": "partnerHub",
                    "enabled": "[parameters('partnerhubEnabled')]"
                  },
                  {
                    "category": "PredictiveOptimization",
                    "enabled": "[parameters('predictiveoptimizationEnabled')]"
                  },
                  {
                    "category": "RBAC",
                    "enabled": "[parameters('rbacEnabled')]"
                  },
                  {
                    "category": "RemoteHistoryService",
                    "enabled": "[parameters('remotehistoryserviceEnabled')]"
                  },
                  {
                    "category": "repos",
                    "enabled": "[parameters('reposEnabled')]"
                  },
                  {
                    "category": "RFA",
                    "enabled": "[parameters('rfaEnabled')]"
                  },
                  {
                    "category": "secrets",
                    "enabled": "[parameters('secretsEnabled')]"
                  },
                  {
                    "category": "serverlessRealTimeInference",
                    "enabled": "[parameters('serverlessrealtimeinferenceEnabled')]"
                  },
                  {
                    "category": "sqlanalytics",
                    "enabled": "[parameters('sqlanalyticsEnabled')]"
                  },
                  {
                    "category": "sqlPermissions",
                    "enabled": "[parameters('sqlpermissionsEnabled')]"
                  },
                  {
                    "category": "ssh",
                    "enabled": "[parameters('sshEnabled')]"
                  },
                  {
                    "category": "unityCatalog",
                    "enabled": "[parameters('unitycatalogEnabled')]"
                  },
                  {
                    "category": "VectorSearch",
                    "enabled": "[parameters('vectorsearchEnabled')]"
                  },
                  {
                    "category": "WebhookNotifications",
                    "enabled": "[parameters('webhooknotificationsEnabled')]"
                  },
                  {
                    "category": "webTerminal",
                    "enabled": "[parameters('webterminalEnabled')]"
                  },
                  {
                    "category": "workspace",
                    "enabled": "[parameters('workspaceEnabled')]"
                  },
                  {
                    "category": "WorkspaceFiles",
                    "enabled": "[parameters('workspacefilesEnabled')]"
                  }
                ]
              }
            }
          }
        }
      }
    }
  }
}
