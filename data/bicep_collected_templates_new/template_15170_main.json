    },
    {
      "condition": "[not(parameters('deployPrivateEndpoints'))]",
      "type": "Microsoft.Sql/servers/firewallRules",
      "apiVersion": "2023-08-01-preview",
      "name": "[format('{0}/{1}', format('sql-{0}-{1}', parameters('appName'), parameters('environment')), 'AllowAllAzureIps')]",
      "properties": {
        "startIpAddress": "0.0.0.0",
        "endIpAddress": "0.0.0.0"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Sql/servers', format('sql-{0}-{1}', parameters('appName'), parameters('environment')))]"
