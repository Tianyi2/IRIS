          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.Cache/redis', format('redis-{0}-{1}', parameters('appName'), parameters('environment')))]"
      ]
    },
    {
      "condition": "[parameters('deployPrivateEndpoints')]",
      "type": "Microsoft.Network/privateEndpoints/privateDnsZoneGroups",
      "apiVersion": "2024-05-01",
      "name": "[format('{0}/{1}', format('pe-{0}', format('redis-{0}-{1}', parameters('appName'), parameters('environment'))), 'default')]",
      "properties": {
        "privateDnsZoneConfigs": [
          {
            "name": "config-redis",
            "properties": {
              "privateDnsZoneId": "[resourceId('Microsoft.Network/privateDnsZones', 'privatelink.redis.cache.windows.net')]"
            }
          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/privateDnsZones', 'privatelink.redis.cache.windows.net')]",
        "[resourceId('Microsoft.Network/privateEndpoints', format('pe-{0}', format('redis-{0}-{1}', parameters('appName'), parameters('environment'))))]"
      ]
    }
