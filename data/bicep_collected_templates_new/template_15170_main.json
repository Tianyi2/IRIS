        "[resourceId('Microsoft.Cache/redis', format('redis-{0}-{1}', parameters('appName'), parameters('environment')))]"
      ]
    },
    {
      "type": "Microsoft.Insights/diagnosticSettings",
      "apiVersion": "2021-05-01-preview",
      "scope": "[resourceId('Microsoft.KeyVault/vaults', format('kv-{0}-{1}', parameters('appName'), parameters('environment')))]",
      "name": "diag-kv",
      "properties": {
        "workspaceId": "[resourceId('Microsoft.OperationalInsights/workspaces', format('law-{0}-{1}', parameters('appName'), parameters('environment')))]",
