        "description": "HTTPS URL of the web frontend container app"
      },
      "value": "[format('https://{0}', reference(resourceId('Microsoft.App/containerApps', format('ca-{0}-web', parameters('appName'))), '2024-03-01').configuration.ingress.fqdn)]"
    },
    "sqlServerFqdn": {
      "type": "string",
      "metadata": {
        "description": "Fully qualified domain name of the SQL Server"
      },
      "value": "[reference(resourceId('Microsoft.Sql/servers', format('sql-{0}-{1}', parameters('appName'), parameters('environment'))), '2023-08-01-preview').fullyQualifiedDomainName]"
    },
    "redisHostname": {
      "type": "string",
