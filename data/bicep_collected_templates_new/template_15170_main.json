{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.41.2.15936",
      "templateHash": "13583627811268187223"
    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region"
      }
    },
    "appName": {
      "type": "string",
      "minLength": 2,
      "maxLength": 12,
      "metadata": {
        "description": "Application name prefix (lowercase alphanumeric, max 12 chars to fit resource naming limits)"
      }
    },
    "apiImage": {
      "type": "string",
      "defaultValue": "mcr.microsoft.com/azuredocs/containerapps-helloworld:latest",
      "metadata": {
        "description": "Container image for the API"
      }
    },
    "webImage": {
      "type": "string",
      "defaultValue": "mcr.microsoft.com/azuredocs/containerapps-helloworld:latest",
      "metadata": {
        "description": "Container image for the web frontend"
      }
    },
    "sqlAdminLogin": {
      "type": "string",
      "minLength": 2,
      "metadata": {
        "description": "SQL administrator login name. Must NOT be a commonly guessed name (admin, administrator, sa, root). Azure will reject these at deployment time."
      }
    },
    "sqlAdminPassword": {
      "type": "securestring",
      "metadata": {
        "description": "SQL admin password"
      }
    },
    "environment": {
      "type": "string",
      "defaultValue": "prod",
      "allowedValues": [
        "prod",
        "nonprod"
      ],
      "metadata": {
        "description": "Environment: prod or nonprod"
      }
    },
    "deployPrivateEndpoints": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "Deploy Private Endpoints for SQL and Redis. When true, you MUST also provide privateEndpointSubnetId and vnetId."
      }
    },
    "privateEndpointSubnetId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Subnet resource ID for Private Endpoints. Required when deployPrivateEndpoints is true. Example: /subscriptions/.../subnets/snet-data"
      }
    },
    "vnetId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "VNet resource ID for Private DNS Zone links. Required when deployPrivateEndpoints is true. Example: /subscriptions/.../virtualNetworks/vnet-prod"
      }
    },
    "tags": {
      "type": "object",
      "defaultValue": {
        "environment": "[parameters('environment')]",
        "team": "engineering",
        "project": "[parameters('appName')]",
        "managedBy": "bicep"
      },
      "metadata": {
        "description": "Resource tags applied to all deployed resources"
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.OperationalInsights/workspaces",
      "apiVersion": "2023-09-01",
      "name": "[format('law-{0}-{1}', parameters('appName'), parameters('environment'))]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "sku": {
          "name": "PerGB2018"
        },
        "retentionInDays": 30
      }
    },
    {
      "type": "Microsoft.App/managedEnvironments",
      "apiVersion": "2024-03-01",
      "name": "[format('cae-{0}-{1}', parameters('appName'), parameters('environment'))]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "appLogsConfiguration": {
          "destination": "log-analytics",
          "logAnalyticsConfiguration": {
            "customerId": "[reference(resourceId('Microsoft.OperationalInsights/workspaces', format('law-{0}-{1}', parameters('appName'), parameters('environment'))), '2023-09-01').customerId]",
            "sharedKey": "[listKeys(resourceId('Microsoft.OperationalInsights/workspaces', format('law-{0}-{1}', parameters('appName'), parameters('environment'))), '2023-09-01').primarySharedKey]"
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.OperationalInsights/workspaces', format('law-{0}-{1}', parameters('appName'), parameters('environment')))]"
      ]
    },
    {
      "type": "Microsoft.App/containerApps",
      "apiVersion": "2024-03-01",
      "name": "[format('ca-{0}-api', parameters('appName'))]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "managedEnvironmentId": "[resourceId('Microsoft.App/managedEnvironments', format('cae-{0}-{1}', parameters('appName'), parameters('environment')))]",
        "configuration": {
          "ingress": {
            "external": true,
            "targetPort": 80,
            "transport": "auto",
            "corsPolicy": {
              "allowedOrigins": [
                "[format('https://ca-{0}-web.{1}', parameters('appName'), reference(resourceId('Microsoft.App/managedEnvironments', format('cae-{0}-{1}', parameters('appName'), parameters('environment'))), '2024-03-01').defaultDomain)]"
              ]
            }
          },
          "secrets": []
        },
        "template": {
          "containers": [
            {
              "name": "api",
              "image": "[parameters('apiImage')]",
              "resources": {
                "cpu": "[json('0.5')]",
                "memory": "1Gi"
              }
            }
