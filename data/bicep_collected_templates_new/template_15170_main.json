    "keyVaultUri": {
      "type": "string",
      "metadata": {
        "description": "Key Vault URI for secret access"
      },
      "value": "[reference(resourceId('Microsoft.KeyVault/vaults', format('kv-{0}-{1}', parameters('appName'), parameters('environment'))), '2023-07-01').vaultUri]"
    }
  }
}