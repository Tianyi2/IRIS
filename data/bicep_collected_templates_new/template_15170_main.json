      "name": "[format('{0}/{1}', format('sql-{0}-{1}', parameters('appName'), parameters('environment')), format('db-{0}', parameters('appName')))]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "sku": {
        "name": "ElasticPool",
        "tier": "Standard"
      },
      "properties": {
        "elasticPoolId": "[resourceId('Microsoft.Sql/servers/elasticPools', format('sql-{0}-{1}', parameters('appName'), parameters('environment')), format('pool-{0}', parameters('appName')))]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Sql/servers/elasticPools', format('sql-{0}-{1}', parameters('appName'), parameters('environment')), format('pool-{0}', parameters('appName')))]",
