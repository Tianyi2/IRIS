      "condition": "[parameters('deployPrivateEndpoints')]",
      "type": "Microsoft.Network/privateDnsZones",
      "apiVersion": "2024-06-01",
      "name": "privatelink.redis.cache.windows.net",
      "location": "global",
      "tags": "[parameters('tags')]"
