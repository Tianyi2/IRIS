          "scale": {
            "minReplicas": "[if(equals(parameters('environment'), 'prod'), 1, 0)]",
            "maxReplicas": 5
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.App/managedEnvironments', format('cae-{0}-{1}', parameters('appName'), parameters('environment')))]"
      ]
    },
