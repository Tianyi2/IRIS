      "dependsOn": [
        "[resourceId('Microsoft.App/containerApps', format('ca-{0}-api', parameters('appName')))]",
        "[resourceId('Microsoft.KeyVault/vaults', format('kv-{0}-{1}', parameters('appName'), parameters('environment')))]"
