      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "sku": {
        "name": "StandardPool",
        "tier": "Standard",
        "capacity": 100
      },
      "properties": {
        "perDatabaseSettings": {
          "minCapacity": 0,
          "maxCapacity": 100
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Sql/servers', format('sql-{0}-{1}', parameters('appName'), parameters('environment')))]"
      ]
    },
