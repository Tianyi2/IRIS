    "secretName": {
      "type": "string"
    },
    "secretValue": {
      "type": "securestring"
    },
    "valueDescription": {
      "type": "string",
      "defaultValue": ""
    }
  },
  "resources": [
    {
      "type": "Microsoft.KeyVault/vaults/secrets",
      "apiVersion": "2022-07-01",
      "name": "[format('{0}/{1}', parameters('keyVaultName'), parameters('secretName'))]",
      "properties": {
        "value": "[parameters('secretValue')]",
        "contentType": "[if(not(empty(parameters('valueDescription'))), parameters('valueDescription'), null())]"
      }
    }
  ],
  "outputs": {
    "secretName": {
      "type": "string",
      "value": "[parameters('secretName')]"
